---
// src/components/ApexCTA.astro
// Affiliate CTA banner. Links through /go/apex (tracked, redirects to the featured firm).
import { AFFILIATE_NAME } from '../consts';
---

<a class="firm-cta" href="/go/apex" target="_blank" rel="sponsored noopener">
  <span class="firm-cta-label">Get funded</span>
  <span class="firm-cta-name">{AFFILIATE_NAME}</span>
  <span class="firm-cta-hint">Start your evaluation →</span>
</a>

<style>
  .firm-cta {
    text-decoration: none;
    text-align: center;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    background: var(--surface);
    border: 2.5px solid var(--accent-bright);
    border-radius: 10px;
    padding: 1rem 2rem;
    margin: 1.25rem 0;
    box-shadow: 0 6px 22px var(--accent-glow);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .firm-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 26px var(--accent-glow);
  }
  .firm-cta:active {
    transform: translateY(0);
    transition-duration: 0.05s;
  }
  .firm-cta-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  .firm-cta-name {
    font-family: var(--font-display, inherit);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-strong);
    line-height: 1.15;
  }
  .firm-cta-hint {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 600;
  }
</style>