---
// src/components/FundingCTA.astro
// The full sponsored card, used across the site so every instance is identical.
import { AFFILIATE_NAME } from '../consts';
import ApexCTA from './ApexCTA.astro';
---

<section class="funding-cta container">
  <div class="cta-card">
    <div class="cta-icon">◆</div>
    <div class="cta-body">
      <div class="cta-eyebrow">Sponsored partner</div>
      <h3>Ready to trade real money?</h3>
      <p>{AFFILIATE_NAME} puts disciplined futures traders on funded accounts from $10K to $250K. If the calculators here made sense to you, you know what to do next.</p>
    </div>
    <ApexCTA />
  </div>
</section>

<style>
.funding-cta { margin-top: 48px; }
  .cta-card {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 28px 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
  }
  @media (max-width: 720px) {
    .cta-card { flex-direction: column; align-items: flex-start; padding: 24px; }
  }
  .cta-icon {
    flex-shrink: 0;
    width: 48px; height: 48px;
    border-radius: 12px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-ring);
    display: grid;
    place-items: center;
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
  }
  .cta-body { flex: 1; }
  .cta-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 6px;
  }
  .cta-card h3 { font-size: 20px; margin-bottom: 4px; color: var(--text-strong); }
  .cta-card p { font-size: 14px; margin: 0; }
</style>