</style>

<script is:inline>
  const CONTRACTS = [
    { sym: 'ES',  name: 'E-mini S and P 500',          cat: 'index',  tickSize: 0.25,    tickValue: 12.50,  pointValue: 50,       micro: false },
    { sym: 'NQ',  name: 'E-mini Nasdaq 100',           cat: 'index',  tickSize: 0.25,    tickValue: 5.00,   pointValue: 20,       micro: false },
    { sym: 'YM',  name: 'E-mini Dow',                  cat: 'index',  tickSize: 1,       tickValue: 5.00,   pointValue: 5,        micro: false },
    { sym: 'RTY', name: 'E-mini Russell 2000',         cat: 'index',  tickSize: 0.10,    tickValue: 5.00,   pointValue: 50,       micro: false },
    { sym: 'MES', name: 'Micro E-mini S and P 500',    cat: 'index',  tickSize: 0.25,    tickValue: 1.25,   pointValue: 5,        micro: true  },
    { sym: 'MNQ', name: 'Micro E-mini Nasdaq 100',     cat: 'index',  tickSize: 0.25,    tickValue: 0.50,   pointValue: 2,        micro: true  },
    { sym: 'MYM', name: 'Micro E-mini Dow',            cat: 'index',  tickSize: 1,       tickValue: 0.50,   pointValue: 0.50,     micro: true  },
    { sym: 'M2K', name: 'Micro E-mini Russell',        cat: 'index',  tickSize: 0.10,    tickValue: 0.50,   pointValue: 5,        micro: true  },
    { sym: 'CL',  name: 'WTI Crude Oil',               cat: 'energy', tickSize: 0.01,    tickValue: 10.00,  pointValue: 1000,     micro: false },
    { sym: 'MCL', name: 'Micro WTI Crude',             cat: 'energy', tickSize: 0.01,    tickValue: 1.00,   pointValue: 100,      micro: true  },
    { sym: 'NG',  name: 'Natural Gas',                 cat: 'energy', tickSize: 0.001,   tickValue: 10.00,  pointValue: 10000,    micro: false },
    { sym: 'RB',  name: 'RBOB Gasoline',               cat: 'energy', tickSize: 0.0001,  tickValue: 4.20,   pointValue: 42000,    micro: false },
    { sym: 'HO',  name: 'Heating Oil',                 cat: 'energy', tickSize: 0.0001,  tickValue: 4.20,   pointValue: 42000,    micro: false },
    { sym: 'GC',  name: 'Gold',                        cat: 'metal',  tickSize: 0.10,    tickValue: 10.00,  pointValue: 100,      micro: false },
    { sym: 'MGC', name: 'Micro Gold',                  cat: 'metal',  tickSize: 0.10,    tickValue: 1.00,   pointValue: 10,       micro: true  },
    { sym: 'SI',  name: 'Silver',                      cat: 'metal',  tickSize: 0.005,   tickValue: 25.00,  pointValue: 5000,     micro: false },
    { sym: 'SIL', name: 'Micro Silver',                cat: 'metal',  tickSize: 0.005,   tickValue: 5.00,   pointValue: 1000,     micro: true  },
    { sym: 'HG',  name: 'Copper',                      cat: 'metal',  tickSize: 0.0005,  tickValue: 12.50,  pointValue: 25000,    micro: false },
    { sym: 'PL',  name: 'Platinum',                    cat: 'metal',  tickSize: 0.10,    tickValue: 5.00,   pointValue: 50,       micro: false },
    { sym: 'ZC',  name: 'Corn',                        cat: 'grain',  tickSize: 0.25,    tickValue: 12.50,  pointValue: 50,       micro: false },
    { sym: 'ZS',  name: 'Soybeans',                    cat: 'grain',  tickSize: 0.25,    tickValue: 12.50,  pointValue: 50,       micro: false },
    { sym: 'ZW',  name: 'Wheat',                       cat: 'grain',  tickSize: 0.25,    tickValue: 12.50,  pointValue: 50,       micro: false },
    { sym: 'ZL',  name: 'Soybean Oil',                 cat: 'grain',  tickSize: 0.01,    tickValue: 6.00,   pointValue: 600,      micro: false },
    { sym: 'ZM',  name: 'Soybean Meal',                cat: 'grain',  tickSize: 0.10,    tickValue: 10.00,  pointValue: 100,      micro: false },
    { sym: 'ZB',  name: '30-Year T-Bond',              cat: 'rate',   tickSize: 0.03125, tickValue: 31.25,  pointValue: 1000,     micro: false },
    { sym: 'ZN',  name: '10-Year T-Note',              cat: 'rate',   tickSize: 0.015625,tickValue: 15.625, pointValue: 1000,     micro: false },
    { sym: 'ZF',  name: '5-Year T-Note',               cat: 'rate',   tickSize: 0.0078125,tickValue: 7.8125,pointValue: 1000,     micro: false },
    { sym: 'ZT',  name: '2-Year T-Note',               cat: 'rate',   tickSize: 0.0078125,tickValue: 15.625,pointValue: 2000,     micro: false },
    { sym: '6E',  name: 'Euro FX',                     cat: 'fx',     tickSize: 0.00005, tickValue: 6.25,   pointValue: 125000,   micro: false },
    { sym: '6B',  name: 'British Pound',               cat: 'fx',     tickSize: 0.0001,  tickValue: 6.25,   pointValue: 62500,    micro: false },
    { sym: '6J',  name: 'Japanese Yen',                cat: 'fx',     tickSize: 0.0000005,tickValue: 6.25,  pointValue: 12500000, micro: false },
    { sym: '6A',  name: 'Australian Dollar',           cat: 'fx',     tickSize: 0.0001,  tickValue: 10.00,  pointValue: 100000,   micro: false },
    { sym: '6C',  name: 'Canadian Dollar',             cat: 'fx',     tickSize: 0.00005, tickValue: 5.00,   pointValue: 100000,   micro: false },
    { sym: 'DX',  name: 'US Dollar Index',             cat: 'fx',     tickSize: 0.005,   tickValue: 5.00,   pointValue: 1000,     micro: false }
  ];

  const tabs = document.querySelectorAll('.tab');
  const panels = document.querySelectorAll('.panel');

  function activateTab(name) {
    let found = false;
    tabs.forEach(t => {
      if (t.dataset.tab === name) {
        t.classList.add('active');
        found = true;
      } else {
        t.classList.remove('active');
      }
    });
    panels.forEach(p => {
      if (p.dataset.panel === name) p.removeAttribute('hidden');
      else p.setAttribute('hidden', '');
    });
    return found;
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      activateTab(tab.dataset.tab);
      // Update the URL hash without reloading, so the user can share the tab they're on
      history.replaceState(null, '', '#' + tab.dataset.tab);
    });
  });

  // On initial load, check if the URL has a hash like #rr or #position
  // If so, open that tab directly. Otherwise default to PnL.
  const initialTab = window.location.hash.replace('#', '');
  if (initialTab && !activateTab(initialTab)) {
    activateTab('pnl');
  }

  function populateSelect(selectEl) {
    if (!selectEl) return;
    const groups = {
      index: 'Index Futures',
      energy: 'Energy',
      metal: 'Metals',
      grain: 'Grains',
      rate: 'Interest Rates',
      fx: 'Currencies'
    };
    Object.entries(groups).forEach(([key, label]) => {
      const og = document.createElement('optgroup');
      og.label = label;
      CONTRACTS.filter(c => c.cat === key).forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.sym;
        opt.textContent = c.sym + ' - ' + c.name;
        og.appendChild(opt);
      });
      selectEl.appendChild(og);
    });
  }

  function getContract(sym) { return CONTRACTS.find(c => c.sym === sym); }

  const fmtMoney = (n) => {
    const r = Math.abs(n);
    const s = r.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return (n < 0 ? '-$' : '$') + s;
  };
  const fmtMoneySigned = (n) => (n >= 0 ? '+' : '') + fmtMoney(n);
  const splitMoney = (n) => {
    const r = Math.abs(n);
    const whole = Math.trunc(r).toLocaleString('en-US');
    const decimal = (r - Math.trunc(r)).toFixed(2).slice(1);
    const sign = n < 0 ? '-' : (n > 0 ? '+' : '');
    return { sign, whole, decimal };
  };
  function setSplitVal(el, n) {
    const parts = splitMoney(n);
    el.innerHTML = parts.sign + '$' + parts.whole + '<span class="dollar">' + parts.decimal + '</span>';
  }

  // ========== PNL ==========
  populateSelect(document.getElementById('pnl-contract'));
  document.getElementById('pnl-contract').value = 'ES';

  const pnl = {
    side: 'long',
    contract: document.getElementById('pnl-contract'),
    entry: document.getElementById('pnl-entry'),
    exit: document.getElementById('pnl-exit'),
    qty: document.getElementById('pnl-qty'),
    comm: document.getElementById('pnl-comm'),
    hint: document.getElementById('pnl-contract-hint'),
    icon: document.getElementById('pnl-icon'),
    status: document.getElementById('pnl-status'),
    headline: document.getElementById('pnl-headline'),
    desc: document.getElementById('pnl-desc'),
    net: document.getElementById('pnl-net'),
    gross: document.getElementById('pnl-gross'),
    ticks: document.getElementById('pnl-ticks'),
    points: document.getElementById('pnl-points'),
    formula: document.getElementById('pnl-formula'),
    cardNet: document.getElementById('pnl-card-net')
  };
  function renderPnl() {
    const c = getContract(pnl.contract.value);
    if (!c) return;
    const entry = parseFloat(pnl.entry.value) || 0;
    const exit = parseFloat(pnl.exit.value) || 0;
    const qty = Math.max(1, parseInt(pnl.qty.value) || 1);
    const comm = Math.max(0, parseFloat(pnl.comm.value) || 0);
    const direction = pnl.side === 'long' ? 1 : -1;
    const points = (exit - entry) * direction;
    const ticks = Math.round(points / c.tickSize);
    const gross = ticks * c.tickValue * qty;
    const totalComm = comm * qty;
    const net = gross - totalComm;

    pnl.hint.textContent = '1 tick = ' + fmtMoney(c.tickValue) + ' / ' + c.tickSize + ' pts';
    setSplitVal(pnl.gross, gross);
    setSplitVal(pnl.net, net);
    pnl.ticks.textContent = ticks + ' t';
    pnl.points.textContent = points.toFixed(c.tickSize < 0.01 ? 4 : 2) + ' points';
    pnl.formula.textContent = '(' + ticks + ' x ' + fmtMoney(c.tickValue) + ') x ' + qty + ' = ' + fmtMoney(gross);

    pnl.cardNet.classList.toggle('positive', net >= 0);
    pnl.cardNet.classList.toggle('negative', net < 0);

    if (net > 0) {
      pnl.status.setAttribute('data-level', 'safe');
      pnl.icon.textContent = '+';
      pnl.headline.textContent = fmtMoneySigned(net) + ' winner';
      pnl.desc.textContent = ticks + ' ticks x ' + fmtMoney(c.tickValue) + ' x ' + qty + ' contract' + (qty > 1 ? 's' : '') + ', minus ' + fmtMoney(totalComm) + ' in commissions.';
    } else if (net < 0) {
      pnl.status.setAttribute('data-level', 'loss');
      pnl.icon.textContent = '-';
      pnl.headline.textContent = fmtMoneySigned(net) + ' loser';
      pnl.desc.textContent = Math.abs(ticks) + ' ticks against you x ' + fmtMoney(c.tickValue) + ' x ' + qty + ' contract' + (qty > 1 ? 's' : '') + ', plus ' + fmtMoney(totalComm) + ' in commissions.';
    } else {
      pnl.status.setAttribute('data-level', 'safe');
      pnl.icon.textContent = '=';
      pnl.headline.textContent = 'Scratch';
      pnl.desc.textContent = 'Flat trade. Commissions cost you ' + fmtMoney(totalComm) + '.';
    }
  }
  ['pnl-contract', 'pnl-entry', 'pnl-exit', 'pnl-qty', 'pnl-comm'].forEach(id => {
    document.getElementById(id).addEventListener('input', renderPnl);
  });
  document.querySelectorAll('[data-input="pnl-side"] button').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-input="pnl-side"] button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      pnl.side = btn.dataset.value;
      renderPnl();
    });
  });
  pnl.contract.addEventListener('change', () => {
    const c = getContract(pnl.contract.value);
    if (c) { pnl.entry.step = c.tickSize; pnl.exit.step = c.tickSize; }
  });
  renderPnl();

  // ========== POSITION SIZE ==========
  populateSelect(document.getElementById('pos-contract'));
  document.getElementById('pos-contract').value = 'ES';

  const pos = {
    contract: document.getElementById('pos-contract'),
    account: document.getElementById('pos-account'),
    riskPct: document.getElementById('pos-risk-pct'),
    stop: document.getElementById('pos-stop'),
    hint: document.getElementById('pos-contract-hint'),
    contracts: document.getElementById('pos-contracts'),
    riskEach: document.getElementById('pos-risk-each'),
    riskTotal: document.getElementById('pos-risk-total'),
    riskPctDisplay: document.getElementById('pos-risk-pct-display'),
    headline: document.getElementById('pos-headline'),
    desc: document.getElementById('pos-desc')
  };
  function renderPos() {
    const c = getContract(pos.contract.value);
    if (!c) return;
    const account = Math.max(0, parseFloat(pos.account.value) || 0);
    const riskPct = Math.max(0, parseFloat(pos.riskPct.value) || 0);
    const stopTicks = Math.max(1, parseInt(pos.stop.value) || 1);

    pos.hint.textContent = '1 tick = ' + fmtMoney(c.tickValue);
    const dollarsAtRisk = account * (riskPct / 100);
    const riskPerContract = stopTicks * c.tickValue;
    const rawContracts = riskPerContract > 0 ? dollarsAtRisk / riskPerContract : 0;
    const contracts = Math.max(0, Math.floor(rawContracts));
    const actualTotalRisk = contracts * riskPerContract;
    const actualPct = account > 0 ? (actualTotalRisk / account) * 100 : 0;

    pos.contracts.textContent = contracts;
    setSplitVal(pos.riskEach, riskPerContract);
    setSplitVal(pos.riskTotal, actualTotalRisk);
    pos.riskPctDisplay.textContent = actualPct.toFixed(2) + '% of account';

    if (contracts === 0) {
      pos.headline.textContent = 'Stop too wide';
      pos.desc.textContent = 'Even one contract would risk ' + fmtMoney(riskPerContract) + ', more than your ' + fmtMoney(dollarsAtRisk) + ' budget. Tighten the stop or accept the larger risk.';
    } else {
      pos.headline.textContent = contracts + ' contract' + (contracts > 1 ? 's' : '');
      pos.desc.textContent = 'Sized to risk ' + fmtMoney(actualTotalRisk) + ' (' + actualPct.toFixed(2) + '% of ' + fmtMoney(account) + ') on a ' + stopTicks + '-tick stop in ' + c.sym + '.';
    }
  }
  ['pos-contract', 'pos-account', 'pos-risk-pct', 'pos-stop'].forEach(id => {
    document.getElementById(id).addEventListener('input', renderPos);
  });
  renderPos();

  // ========== REFERENCE ==========
  const tbody = document.getElementById('ref-tbody');
  const catNames = { index: 'Index', energy: 'Energy', metal: 'Metal', grain: 'Grain', rate: 'Rates', fx: 'FX' };
  function renderRef(filter) {
    if (!filter) filter = 'all';
    tbody.innerHTML = '';
    let rows = CONTRACTS;
    if (filter === 'micro') rows = rows.filter(r => r.micro);
    else if (filter !== 'all') rows = rows.filter(r => r.cat === filter);
    rows.forEach(c => {
      const tr = document.createElement('tr');
      const catLabel = catNames[c.cat] + (c.micro ? ' / micro' : '');
      tr.innerHTML =
        '<td class="sym">' + c.sym + '</td>' +
        '<td>' + c.name + '</td>' +
        '<td class="cat">' + catLabel + '</td>' +
        '<td class="num">' + c.tickSize + '</td>' +
        '<td class="num">' + fmtMoney(c.tickValue) + '</td>' +
        '<td class="num">' + fmtMoney(c.pointValue) + '</td>';
      tbody.appendChild(tr);
    });
  }
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      renderRef(btn.dataset.filter);
    });
  });
  renderRef();

  // ========== RISK / REWARD ==========
  const rr = {
    side: 'long',
    mode: 'percent',
    targets: [
      { price: 5210, alloc: 50 },
      { price: 5220, alloc: 25 },
      { price: 5230, alloc: 25 }
    ],
    contract: document.getElementById('rr-contract'),
    entry: document.getElementById('rr-entry'),
    stop: document.getElementById('rr-stop'),
    qty: document.getElementById('rr-qty'),
    hint: document.getElementById('rr-contract-hint'),
    targetsContainer: document.getElementById('rr-targets'),
    addBtn: document.getElementById('rr-add-target'),
    icon: document.getElementById('rr-icon'),
    status: document.getElementById('rr-status'),
    headline: document.getElementById('rr-headline'),
    desc: document.getElementById('rr-desc'),
    risk: document.getElementById('rr-risk'),
    reward: document.getElementById('rr-reward'),
    rr: document.getElementById('rr-rr'),
    rrSub: document.getElementById('rr-rr-sub'),
    rows: document.getElementById('rr-rows'),
    cardRisk: document.getElementById('rr-card-risk'),
    cardReward: document.getElementById('rr-card-reward'),
    cardRR: document.getElementById('rr-card-rr')
  };
  populateSelect(rr.contract);
  if (rr.contract) rr.contract.value = 'ES';

  function renderTargetRows() {
    if (!rr.targetsContainer) return;
    rr.targetsContainer.innerHTML = '';
    const allocLabel = rr.mode === 'percent' ? '% of position' : 'Contracts';
    rr.targets.forEach((t, i) => {
      const row = document.createElement('div');
      row.className = 'target-row';
      row.innerHTML =
        '<div class="target-tag">T' + (i + 1) + '</div>' +
        '<div><label>Price</label><input type="number" data-rr-target="price" data-i="' + i + '" value="' + t.price + '" step="' + (getContract(rr.contract.value)?.tickSize || 0.25) + '" /></div>' +
        '<div><label>' + allocLabel + '</label><input type="number" data-rr-target="alloc" data-i="' + i + '" value="' + t.alloc + '" step="1" min="0" /></div>' +
        '<button type="button" class="remove-btn" data-rr-remove="' + i + '"' + (rr.targets.length === 1 ? ' disabled' : '') + '>x</button>';
      rr.targetsContainer.appendChild(row);
    });
    rr.targetsContainer.querySelectorAll('input[data-rr-target]').forEach(input => {
      input.addEventListener('input', () => {
        const i = parseInt(input.dataset.i);
        const field = input.dataset.rrTarget;
        rr.targets[i][field] = parseFloat(input.value) || 0;
        renderRR();
      });
    });
    rr.targetsContainer.querySelectorAll('[data-rr-remove]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (rr.targets.length <= 1) return;
        const i = parseInt(btn.dataset.rrRemove);
        rr.targets.splice(i, 1);
        renderTargetRows();
        renderRR();
      });
    });
    if (rr.addBtn) rr.addBtn.disabled = rr.targets.length >= 8;
  }

  if (rr.addBtn) {
    rr.addBtn.addEventListener('click', () => {
      const last = rr.targets[rr.targets.length - 1];
      const c = getContract(rr.contract.value);
      const direction = rr.side === 'long' ? 1 : -1;
      const stepPoints = c ? c.tickSize * 20 : 5;
      rr.targets.push({
        price: parseFloat((last.price + (stepPoints * direction)).toFixed(4)),
        alloc: rr.mode === 'percent' ? 25 : 1
      });
      renderTargetRows();
      renderRR();
    });
  }

  function renderRR() {
    if (!rr.contract) return;
    const c = getContract(rr.contract.value);
    if (!c) return;
    const entry = parseFloat(rr.entry.value) || 0;
    const stop = parseFloat(rr.stop.value) || 0;
    const totalQty = Math.max(1, parseInt(rr.qty.value) || 1);
    const direction = rr.side === 'long' ? 1 : -1;

    rr.hint.textContent = '1 tick = ' + fmtMoney(c.tickValue) + ' / ' + c.tickSize + ' pts';

    const stopPoints = (entry - stop) * direction;
    const stopTicks = stopPoints / c.tickSize;
    const dollarsPerContractAtStop = stopTicks * c.tickValue;
    const totalRisk = dollarsPerContractAtStop * totalQty;

    let totalReward = 0;
    let allocSum = 0;
    const breakdown = [];

    rr.targets.forEach((t, i) => {
      const targetPoints = (t.price - entry) * direction;
      const targetTicks = targetPoints / c.tickSize;
      const dollarsPerContract = targetTicks * c.tickValue;
      let qtyAtTarget = rr.mode === 'percent' ? totalQty * (t.alloc / 100) : t.alloc;
      allocSum += rr.mode === 'percent' ? t.alloc : qtyAtTarget;
      const dollarsAtTarget = dollarsPerContract * qtyAtTarget;
      totalReward += dollarsAtTarget;
      const r = totalRisk > 0 ? dollarsAtTarget / totalRisk : 0;
      const distLabel = (targetPoints >= 0 ? '+' : '') + targetPoints.toFixed(c.tickSize < 0.01 ? 4 : 2) + ' pts';
      const qtyLabel = (qtyAtTarget % 1 === 0 ? qtyAtTarget : qtyAtTarget.toFixed(2)) + ' c';
      breakdown.push({ tag: 'T' + (i + 1), dist: distLabel, qty: qtyLabel, dollars: dollarsAtTarget, r });
    });

    const blendedRR = totalRisk > 0 ? totalReward / totalRisk : 0;
    setSplitVal(rr.risk, -Math.abs(totalRisk));
    setSplitVal(rr.reward, totalReward);
    rr.rr.textContent = blendedRR.toFixed(2);
    rr.cardRR.classList.toggle('positive', blendedRR >= 1);
    rr.cardRR.classList.toggle('negative', blendedRR < 1);

    rr.rows.innerHTML = '';
    breakdown.forEach(b => {
      const row = document.createElement('div');
      row.className = 'rr-row';
      const dollarsClass = b.dollars >= 0 ? 'dollars' : 'dollars neg';
      row.innerHTML =
        '<span class="tag">' + b.tag + '</span>' +
        '<span class="meta">' + b.dist + '</span>' +
        '<span class="meta">' + b.qty + '</span>' +
        '<span class="' + dollarsClass + '">' + (b.dollars >= 0 ? '+' : '') + fmtMoney(b.dollars) + '</span>' +
        '<span class="r">' + b.r.toFixed(2) + ' R</span>';
      rr.rows.appendChild(row);
    });

    let breakeven = blendedRR > 0 ? (1 / (1 + blendedRR)) * 100 : 100;
    if (totalRisk <= 0) {
      rr.status.setAttribute('data-level', 'loss');
      rr.icon.textContent = '!';
      rr.headline.textContent = 'Stop on the wrong side';
      rr.desc.textContent = 'Your stop is at or past your entry on this direction. Move it past the entry to define risk.';
    } else if (rr.mode === 'percent' && Math.abs(allocSum - 100) > 0.5) {
      rr.status.setAttribute('data-level', 'loss');
      rr.icon.textContent = '!';
      rr.headline.textContent = 'Allocations should total 100%';
      rr.desc.textContent = 'Your target percentages currently sum to ' + allocSum.toFixed(0) + '%. Adjust them so the position fully exits.';
    } else if (blendedRR >= 2) {
      rr.status.setAttribute('data-level', 'safe');
      rr.icon.textContent = 'R';
      rr.headline.textContent = blendedRR.toFixed(2) + ' R';
      rr.desc.textContent = 'Solid plan. Risks ' + fmtMoney(totalRisk) + ' to make ' + fmtMoney(totalReward) + ' if all targets fill. Profitable above a ' + breakeven.toFixed(0) + '% win rate.';
    } else if (blendedRR >= 1) {
      rr.status.setAttribute('data-level', 'safe');
      rr.icon.textContent = 'R';
      rr.headline.textContent = blendedRR.toFixed(2) + ' R';
      rr.desc.textContent = 'Decent plan. Risks ' + fmtMoney(totalRisk) + ' to make ' + fmtMoney(totalReward) + '. Needs above a ' + breakeven.toFixed(0) + '% win rate to be profitable.';
    } else {
      rr.status.setAttribute('data-level', 'loss');
      rr.icon.textContent = 'R';
      rr.headline.textContent = blendedRR.toFixed(2) + ' R';
      rr.desc.textContent = 'Below 1 R, the math gets ugly. Needs above a ' + breakeven.toFixed(0) + '% win rate just to break even. Tighten the stop or push the targets.';
    }
  }

  ['rr-contract', 'rr-entry', 'rr-stop', 'rr-qty'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', renderRR);
  });
  document.querySelectorAll('[data-input="rr-side"] button').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-input="rr-side"] button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      rr.side = btn.dataset.value;
      renderRR();
    });
  });
  document.querySelectorAll('[data-input="rr-mode"] button').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-input="rr-mode"] button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const newMode = btn.dataset.value;
      const totalQty = Math.max(1, parseInt(rr.qty.value) || 1);
      if (newMode === 'contracts' && rr.mode === 'percent') {
        rr.targets = rr.targets.map(t => ({ price: t.price, alloc: Math.max(1, Math.round(totalQty * (t.alloc / 100))) }));
      } else if (newMode === 'percent' && rr.mode === 'contracts') {
        const sum = rr.targets.reduce((s, t) => s + t.alloc, 0) || 1;
        rr.targets = rr.targets.map(t => ({ price: t.price, alloc: Math.round((t.alloc / sum) * 100) }));
      }
      rr.mode = newMode;
      renderTargetRows();
      renderRR();
    });
  });
  if (rr.contract) {
    rr.contract.addEventListener('change', () => {
      const c = getContract(rr.contract.value);
      if (c) { rr.entry.step = c.tickSize; rr.stop.step = c.tickSize; }
      renderTargetRows();
      renderRR();
    });
  }

  renderTargetRows();
  renderRR();
</script>