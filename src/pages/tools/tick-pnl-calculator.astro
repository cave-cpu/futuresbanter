---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead
    title="Futures Tick and PnL Calculator — FuturesBanter"
    description="Free futures tick value, profit and loss, position sizing, and risk-reward calculator. Supports 30+ contracts including ES, NQ, CL, GC, micros, grains, currencies, and bonds."
  />
</head>
<body>
  <Header />

  <main>
    <div class="container calc-page">

      <section class="calc-hero">
        <div class="kicker"><span class="kicker-dot"></span>Trader Tools / 002</div>
        <h1>Futures <em>Tick and PnL</em> Calculator</h1>
        <p class="subtitle">Four tools, one page. Run a P&amp;L on any trade, plan a risk-reward setup with multiple targets, look up tick values for 30+ contracts, or size a position based on your stop. Bookmark it &mdash; you'll be back.</p>
      </section>

      <div class="tabs" role="tablist">
        <button class="tab active" data-tab="pnl" type="button">PnL Calculator</button>
        <button class="tab" data-tab="rr" type="button">Risk / Reward</button>
        <button class="tab" data-tab="reference" type="button">Tick Reference</button>
        <button class="tab" data-tab="position" type="button">Position Size</button>
      </div>

      <!-- ============== PNL CALCULATOR ============== -->
      <section class="panel" data-panel="pnl">
        <div class="panel-grid">

          <div class="card inputs">
            <h2 class="section-label">Trade Setup</h2>

            <div class="field">
              <label>Contract</label>
              <select id="pnl-contract"></select>
              <div class="field-hint" id="pnl-contract-hint">1 tick = $12.50</div>
            </div>

            <div class="field">
              <label>Direction</label>
              <div class="segmented" data-input="pnl-side">
                <button type="button" data-value="long" class="active">Long</button>
                <button type="button" data-value="short">Short</button>
              </div>
            </div>

            <div class="two-col">
              <div class="field">
                <label>Entry</label>
                <input type="number" id="pnl-entry" value="5200.00" step="0.25" />
              </div>
              <div class="field">
                <label>Exit</label>
                <input type="number" id="pnl-exit" value="5210.00" step="0.25" />
              </div>
            </div>

            <div class="field">
              <label>Contracts</label>
              <input type="number" id="pnl-qty" value="1" min="1" step="1" />
            </div>

            <div class="divider"></div>

            <div class="field">
              <label>Round-Trip Commission <span class="hint">per contract</span></label>
              <div class="dollar-input"><input type="number" id="pnl-comm" value="4.00" step="0.10" min="0" /></div>
            </div>
          </div>

          <div class="results">
            <div class="status" data-level="safe" id="pnl-status">
              <div class="status-icon" id="pnl-icon">+</div>
              <div class="content">
                <div class="status-eyebrow">Result</div>
                <div class="headline" id="pnl-headline">+$500.00 winner</div>
                <div class="desc" id="pnl-desc">10 points times $50 per point times 1 contract, minus $4 in commissions.</div>
              </div>
            </div>

            <div class="numbers">
              <div class="number positive" id="pnl-card-net">
                <div class="lbl">Net PnL</div>
                <div class="val" id="pnl-net">+$496<span class="dollar">.00</span></div>
                <div class="sub">after commissions</div>
              </div>
              <div class="number" id="pnl-card-gross">
                <div class="lbl">Gross PnL</div>
                <div class="val" id="pnl-gross">+$500<span class="dollar">.00</span></div>
                <div class="sub">before fees</div>
              </div>
              <div class="number" id="pnl-card-ticks">
                <div class="lbl">Move</div>
                <div class="val" id="pnl-ticks">40 t</div>
                <div class="sub" id="pnl-points">10.00 points</div>
              </div>
            </div>

            <div class="explainer">
              <div class="explainer-eyebrow">The math</div>
              <p><span class="mono" id="pnl-formula">(40 x $12.50) x 1 contract = $500.00</span></p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============== RISK / REWARD ============== -->
      <section class="panel" data-panel="rr" hidden>
        <div class="panel-grid">

          <div class="card inputs">
            <h2 class="section-label">Trade Plan</h2>

            <div class="field">
              <label>Contract</label>
              <select id="rr-contract"></select>
              <div class="field-hint" id="rr-contract-hint">1 tick = $12.50</div>
            </div>

            <div class="field">
              <label>Direction</label>
              <div class="segmented" data-input="rr-side">
                <button type="button" data-value="long" class="active">Long</button>
                <button type="button" data-value="short">Short</button>
              </div>
            </div>

            <div class="field">
              <label>Scaling Mode</label>
              <div class="segmented" data-input="rr-mode">
                <button type="button" data-value="percent" class="active">% of Position</button>
                <button type="button" data-value="contracts">Exact Contracts</button>
              </div>
            </div>

            <div class="divider"></div>

            <div class="two-col">
              <div class="field">
                <label>Entry</label>
                <input type="number" id="rr-entry" value="5200.00" step="0.25" />
              </div>
              <div class="field">
                <label>Stop</label>
                <input type="number" id="rr-stop" value="5195.00" step="0.25" />
              </div>
            </div>

            <div class="field">
              <label>Total Contracts</label>
              <input type="number" id="rr-qty" value="4" min="1" step="1" />
            </div>

            <div class="divider"></div>

            <div class="targets-head">
              <span class="targets-label">Targets</span>
              <button type="button" id="rr-add-target" class="add-btn">+ Add target</button>
            </div>

            <div id="rr-targets"></div>
          </div>

          <div class="results">
            <div class="status" data-level="safe" id="rr-status">
              <div class="status-icon" id="rr-icon">R</div>
              <div class="content">
                <div class="status-eyebrow">Blended R / R</div>
                <div class="headline" id="rr-headline">2.10 R</div>
                <div class="desc" id="rr-desc">Plan risks $200 to make $420 if all targets fill.</div>
              </div>
            </div>

            <div class="numbers">
              <div class="number negative" id="rr-card-risk">
                <div class="lbl">Risk</div>
                <div class="val" id="rr-risk"><span class="dollar">-$</span>200<span class="dollar">.00</span></div>
                <div class="sub" id="rr-risk-sub">if stop hits</div>
              </div>
              <div class="number positive" id="rr-card-reward">
                <div class="lbl">Reward</div>
                <div class="val" id="rr-reward">+$420<span class="dollar">.00</span></div>
                <div class="sub" id="rr-reward-sub">if all targets fill</div>
              </div>
              <div class="number positive" id="rr-card-rr">
                <div class="lbl">Blended R / R</div>
                <div class="val" id="rr-rr">2.10</div>
                <div class="sub" id="rr-rr-sub">reward per $1 risked</div>
              </div>
            </div>

            <div class="rr-breakdown" id="rr-breakdown">
              <div class="rr-breakdown-head">
                <div class="explainer-eyebrow">Per-target breakdown</div>
                <span class="rr-breakdown-hint">Distance / contracts / dollars / R</span>
              </div>
              <div class="rr-rows" id="rr-rows"></div>
            </div>

            <div class="explainer">
              <div class="explainer-eyebrow">How blended R / R works</div>
              <p>Each target's reward is weighted by how many contracts you exit there. Add them up and divide by total risk. A blended <strong>2.0 R</strong> means you make $2 for every $1 risked when the plan plays out perfectly. Most pros aim for blended <strong>1.5 R</strong> or higher; below 1.0 R the math rarely works long term.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============== TICK REFERENCE ============== -->
      <section class="panel" data-panel="reference" hidden>
        <div class="reference-head">
          <h2>Tick Reference</h2>
          <p>The minimum tick size, dollar value per tick, and dollar value per point for every contract this calculator supports. Use it as a lookup. Bookmark it as a cheat sheet.</p>

          <div class="filters">
            <button class="filter-btn active" data-filter="all" type="button">All</button>
            <button class="filter-btn" data-filter="index" type="button">Index</button>
            <button class="filter-btn" data-filter="energy" type="button">Energy</button>
            <button class="filter-btn" data-filter="metal" type="button">Metals</button>
            <button class="filter-btn" data-filter="grain" type="button">Grains</button>
            <button class="filter-btn" data-filter="rate" type="button">Rates</button>
            <button class="filter-btn" data-filter="fx" type="button">FX</button>
            <button class="filter-btn" data-filter="micro" type="button">Micros only</button>
          </div>
        </div>

        <div class="ref-table-wrap">
          <table class="ref-table" id="ref-table">
            <thead>
              <tr>
                <th>Symbol</th>
                <th>Name</th>
                <th>Category</th>
                <th class="num">Tick Size</th>
                <th class="num">Tick Value</th>
                <th class="num">Point Value</th>
              </tr>
            </thead>
            <tbody id="ref-tbody"></tbody>
          </table>
        </div>
      </section>

      <!-- ============== POSITION SIZE ============== -->
      <section class="panel" data-panel="position" hidden>
        <div class="panel-grid">
          <div class="card inputs">
            <h2 class="section-label">Risk Setup</h2>

            <div class="field">
              <label>Contract</label>
              <select id="pos-contract"></select>
              <div class="field-hint" id="pos-contract-hint">1 tick = $12.50</div>
            </div>

            <div class="divider"></div>

            <div class="field">
              <label>Account Size</label>
              <div class="dollar-input"><input type="number" id="pos-account" value="50000" step="1000" min="0" /></div>
            </div>

            <div class="field">
              <label>Risk Per Trade <span class="hint">% of account</span></label>
              <input type="number" id="pos-risk-pct" value="1" step="0.1" min="0" />
            </div>

            <div class="field">
              <label>Stop Distance <span class="hint">in ticks</span></label>
              <input type="number" id="pos-stop" value="8" min="1" step="1" />
            </div>
          </div>

          <div class="results">
            <div class="status" data-level="safe" id="pos-status">
              <div class="status-icon">+</div>
              <div class="content">
                <div class="status-eyebrow">Suggested Size</div>
                <div class="headline" id="pos-headline">5 contracts</div>
                <div class="desc" id="pos-desc">Sized to risk $500 (1% of $50,000) on an 8-tick stop in ES.</div>
              </div>
            </div>

            <div class="numbers">
              <div class="number positive">
                <div class="lbl">Contracts</div>
                <div class="val" id="pos-contracts">5</div>
                <div class="sub">whole contracts</div>
              </div>
              <div class="number">
                <div class="lbl">Risk Per Contract</div>
                <div class="val" id="pos-risk-each"><span class="dollar">$</span>100</div>
                <div class="sub">8 t times tick value</div>
              </div>
              <div class="number">
                <div class="lbl">Total Risk</div>
                <div class="val" id="pos-risk-total"><span class="dollar">$</span>500</div>
                <div class="sub" id="pos-risk-pct-display">1.00% of account</div>
              </div>
            </div>

            <div class="explainer">
              <div class="explainer-eyebrow">How it works</div>
              <p><strong>Contracts = (Account x Risk %) divided by (Stop Ticks x Tick Value)</strong>, rounded down. Rounding down keeps you under your risk cap, never over.</p>
            </div>
          </div>
        </div>
      </section>

      <div class="cta">
        <div class="cta-icon">◆</div>
        <div class="cta-body">
          <div class="cta-eyebrow">Sponsored</div>
          <h4>Ready to put these tools to work?</h4>
          <p>Apex funds disciplined futures traders with accounts up to $300K. Risk their money, not yours.</p>
        </div>
        <a href="/go/apex" class="cta-btn" target="_blank" rel="sponsored noopener">Start evaluation</a>
      </div>

      <div class="calc-disclaimer">
        <p><strong>Not financial advice.</strong> Tick values reflect CME Group specifications as of 2026. Always verify with your broker before trading. Some contracts (DX, ZT, ZF, ZN) use fractional tick sizes; values shown are decimal equivalents.</p>
      </div>

    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  .calc-page { padding-top: 24px; }

  .calc-hero {
    margin-bottom: 36px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
  }
  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    padding: 6px 12px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-ring);
    border-radius: 999px;
  }
  .kicker-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent-glow);
  }
  .calc-hero h1 { margin-bottom: 18px; max-width: 900px; }
  .calc-hero h1 em {
    font-style: normal;
    background: linear-gradient(135deg, var(--accent-bright), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .subtitle {
    font-size: 17px;
    color: var(--text-muted);
    max-width: 640px;
    line-height: 1.6;
  }

  .tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .tab {
    background: transparent;
    border: none;
    color: var(--text-muted);
    padding: 12px 18px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border-radius: 8px 8px 0 0;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all 0.15s;
  }
  .tab:hover { color: var(--text); background: var(--surface); }
  .tab.active {
    color: var(--accent-bright);
    border-bottom-color: var(--accent);
    background: var(--accent-bg);
  }

  .panel { animation: fadein 0.2s ease; }
  @keyframes fadein {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .panel-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 24px;
    align-items: start;
  }
  @media (max-width: 960px) {
    .panel-grid { grid-template-columns: 1fr; gap: 20px; }
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
  }
  .inputs {
    padding: 28px;
    position: sticky;
    top: 124px;
  }
  @media (max-width: 960px) {
    .inputs { position: static; padding: 24px; }
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 0 0 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }
  .field { margin-bottom: 18px; }
  .field:last-child { margin-bottom: 0; }
  .field-hint {
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
  }

  label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 8px;
  }
  label .hint {
    color: var(--text-dim);
    font-weight: 400;
    margin-left: 8px;
    font-size: 12px;
  }

  .segmented {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 3px;
    gap: 2px;
  }
  .segmented button {
    background: transparent;
    border: none;
    color: var(--text-muted);
    padding: 9px 12px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    border-radius: 7px;
    transition: all 0.15s;
  }
  .segmented button:hover:not(.active) { color: var(--text); background: var(--surface-hover); }
  .segmented button.active {
    background: var(--surface-2);
    color: var(--text-strong);
    font-weight: 600;
    box-shadow: 0 1px 2px rgba(0,0,0,0.3), inset 0 0 0 1px var(--border-accent);
  }

  select, input[type="number"] {
    width: 100%;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
    padding: 11px 14px;
    transition: all 0.15s;
  }
  select:hover, input[type="number"]:hover { border-color: var(--border-strong); }
  select:focus, input[type="number"]:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-ring);
  }
  select {
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 8' fill='none'><path d='M1 1.5L6 6.5L11 1.5' stroke='%239699a1' stroke-width='1.5' stroke-linecap='round'/></svg>");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 40px;
  }
  .dollar-input { position: relative; }
  .dollar-input::before {
    content: '$';
    position: absolute;
    left: 14px; top: 50%;
    transform: translateY(-50%);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
    pointer-events: none;
    z-index: 1;
  }
  .dollar-input input { padding-left: 28px; }
  input[type=number]::-webkit-inner-spin-button,
  input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
  input[type=number] { -moz-appearance: textfield; }

  .divider { height: 1px; background: var(--border); margin: 22px -28px; }
  @media (max-width: 960px) { .divider { margin: 20px -24px; } }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  .results { display: flex; flex-direction: column; gap: 16px; }

  .status {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px 28px;
    display: flex;
    align-items: center;
    gap: 20px;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .status::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent);
  }
  .status-icon {
    flex-shrink: 0;
    width: 48px; height: 48px;
    border-radius: 12px;
    background: var(--accent-bg);
    border: 1px solid var(--accent-ring);
    display: grid; place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--accent);
  }
  .status-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 4px;
  }
  .status .headline {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 24px;
    line-height: 1.2;
    margin-bottom: 4px;
    color: var(--text-strong);
    letter-spacing: -0.015em;
  }
  .status .desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.5;
    max-width: 540px;
  }
  .status[data-level="loss"]::before { background: var(--danger); }
  .status[data-level="loss"] .status-icon {
    background: var(--danger-bg); border-color: var(--danger-ring); color: var(--danger);
  }
  .status[data-level="loss"] .headline { color: var(--danger-bright); }

  .numbers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 720px) { .numbers { grid-template-columns: 1fr; } }
  .number {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 24px;
    transition: border-color 0.2s;
    box-shadow: var(--shadow-sm);
  }
  .number:hover { border-color: var(--border-strong); }
  .number .lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 12px;
  }
  .number .val {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 30px;
    letter-spacing: -0.025em;
    color: var(--text-strong);
    line-height: 1;
  }
  .number .val .dollar {
    color: var(--text-dim);
    font-size: 19px;
    font-weight: 500;
    margin-right: 1px;
  }
  .number .sub { font-size: 12px; color: var(--text-muted); margin-top: 10px; }
  .number.positive .val { color: var(--accent-bright); }
  .number.positive .val .dollar { color: var(--accent-dim); }
  .number.negative .val { color: var(--danger-bright); }
  .number.negative .val .dollar { color: var(--danger); opacity: 0.7; }

  .explainer {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 22px;
    box-shadow: var(--shadow-sm);
  }
  .explainer-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 8px;
  }
  .explainer p { color: var(--text-muted); font-size: 14px; margin: 0; }
  .explainer .mono {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text);
    background: var(--bg-raised);
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  .explainer p strong { color: var(--text); font-weight: 600; }

