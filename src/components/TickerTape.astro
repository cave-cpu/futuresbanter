---
// TradingView Ticker Tape — adapts to light/dark theme
---

<div class="ticker-wrap">
  <div id="ticker-dark" class="ticker-instance">
    <div class="tradingview-widget-container">
      <div class="tradingview-widget-container__widget"></div>
      <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js" async is:inline>
        {
          "symbols": [
            { "proName": "AMEX:SPY",        "title": "S&P 500" },
            { "proName": "NASDAQ:QQQ",      "title": "Nasdaq 100" },
            { "proName": "AMEX:DIA",        "title": "Dow" },
            { "proName": "AMEX:IWM",        "title": "Russell 2000" },
            { "proName": "AMEX:USO",        "title": "Crude Oil" },
            { "proName": "AMEX:GLD",        "title": "Gold" },
            { "proName": "AMEX:SLV",        "title": "Silver" },
            { "proName": "NASDAQ:TLT",      "title": "20Y Bonds" },
            { "proName": "TVC:DXY",         "title": "Dollar Index" },
            { "proName": "BITSTAMP:BTCUSD", "title": "Bitcoin" }
          ],
          "showSymbolLogo": false,
          "isTransparent": true,
          "displayMode": "adaptive",
          "colorTheme": "dark",
          "locale": "en"
        }
      </script>
    </div>
  </div>

  <div id="ticker-light" class="ticker-instance">
    <div class="tradingview-widget-container">
      <div class="tradingview-widget-container__widget"></div>
      <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js" async is:inline>
        {
          "symbols": [
            { "proName": "AMEX:SPY",        "title": "S&P 500" },
            { "proName": "NASDAQ:QQQ",      "title": "Nasdaq 100" },
            { "proName": "AMEX:DIA",        "title": "Dow" },
            { "proName": "AMEX:IWM",        "title": "Russell 2000" },
            { "proName": "AMEX:USO",        "title": "Crude Oil" },
            { "proName": "AMEX:GLD",        "title": "Gold" },
            { "proName": "AMEX:SLV",        "title": "Silver" },
            { "proName": "NASDAQ:TLT",      "title": "20Y Bonds" },
            { "proName": "TVC:DXY",         "title": "Dollar Index" },
            { "proName": "BITSTAMP:BTCUSD", "title": "Bitcoin" }
          ],
          "showSymbolLogo": false,
          "isTransparent": true,
          "displayMode": "adaptive",
          "colorTheme": "light",
          "locale": "en"
        }
      </script>
    </div>
  </div>
</div>

<style>
  .ticker-wrap {
    background: var(--bg-raised);
    border-bottom: 1px solid var(--border);
    padding: 4px 0;
    position: sticky;
    top: 64px;
    z-index: 49;
  }
  .ticker-instance {
    min-height: 40px;
  }

  /* Default (dark theme): show dark, hide light */
  .ticker-wrap #ticker-light { display: none !important; }
  .ticker-wrap #ticker-dark { display: block !important; }

  /* Light theme: invert */
  :global([data-theme="light"]) .ticker-wrap #ticker-dark { display: none !important; }
  :global([data-theme="light"]) .ticker-wrap #ticker-light { display: block !important; }
</style>