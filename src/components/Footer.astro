---
const today = new Date();
---

<footer>
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="brand-text">Futures<em>Banter</em></span>
        <p>Trader tools, prop firm reviews, and plain-English breakdowns for futures traders. No fluff, no shilling.</p>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <h4>Tools</h4>
          <ul>
            <li><a href="/tools/apex-drawdown-calculator">Apex Drawdown Calculator</a></li>
            <li><a href="/tools/tick-pnl-calculator">Tick &amp; P&amp;L Calculator</a></li>
		  </ul>
        </div>
        <div class="footer-col">
          <h4>Site</h4>
          <ul>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/about">About</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="legal">
        <strong>Affiliate disclosure:</strong> FuturesBanter earns a commission on qualifying sign-ups to partner prop firms. Opinions are our own. Nothing on this site is financial advice — we're traders sharing tools and notes, not licensed advisors. Trading futures carries significant risk of loss.
      </p>
      <p class="copyright">&copy; {today.getFullYear()} FuturesBanter. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 96px;
    border-top: 1px solid var(--border);
    background: var(--bg-raised);
    padding: 56px 0 32px;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }
  @media (max-width: 720px) {
    .footer-top { grid-template-columns: 1fr; gap: 32px; }
  }

  .footer-brand .brand-text {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: var(--text-strong);
    letter-spacing: -0.02em;
    display: inline-block;
    margin-bottom: 12px;
  }
  .footer-brand em { font-style: normal; color: var(--accent); }
  .footer-brand p { max-width: 380px; font-size: 14.5px; }

  .footer-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .footer-col h4 {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 14px;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col a {
    color: var(--text-muted);
    font-size: 14px;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: var(--accent-bright); }

  .footer-bottom {
    padding-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .legal {
    font-size: 12.5px;
    color: var(--text-dim);
    line-height: 1.55;
    max-width: 880px;
  }
  .legal strong { color: var(--text-muted); font-weight: 600; }

  .copyright {
    font-size: 12.5px;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }
</style>